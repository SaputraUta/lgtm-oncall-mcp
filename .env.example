# ─────────────────────────────────────────────────────────────────────
# lgtm-oncall-mcp — configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────

# ===== Grafana (UI + datasource proxy) =====
# Base URL of your Grafana instance.
GRAFANA_URL=https://grafana.example.com

# Grafana service-account token (Editor scope is enough for read tools,
# Admin if you want capture_dashboard via /render or alerts mgmt).
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxx

# Mimir / Prometheus datasource UID in Grafana
# (Grafana → Connections → Data sources → click your Mimir source → UID).
MIMIR_DS_UID=

# Loki datasource UID (same path).
LOKI_DS_UID=

# Optional: pin the Grafana TLS cert to a file (recommended for self-signed).
# Leave empty to use system trust store.
# GRAFANA_CA_CERT_PATH=/etc/lgtm-oncall-mcp/grafana-ca.pem


# ===== Label conventions =====
# All PromQL/LogQL queries are templated with these label keys.
# Adjust to match how your services are labeled in Mimir/Loki.

# Label key that identifies the environment (dev/staging/prod).
ENV_LABEL_KEY=env

# Label key that identifies your team (set blank to disable team filtering).
TEAM_LABEL_KEY=team

# Team label value (leave blank to disable).
TEAM_LABEL_VALUE=


# ===== VCS / deploy backend =====
# Which provider to use for deploys + commit history. Options: bitbucket, github
VCS_PROVIDER=bitbucket

# ── Bitbucket Cloud (when VCS_PROVIDER=bitbucket) ──
# Atlassian API token (NOT username+password). Email + token Basic auth.
# Token scopes needed: read:repository:bitbucket, read:pullrequest:bitbucket,
#                     write:repository:bitbucket, write:pullrequest:bitbucket,
#                     read:pipeline:bitbucket, write:pipeline:bitbucket
BITBUCKET_EMAIL=
BITBUCKET_API_TOKEN=
BITBUCKET_WORKSPACE=
BITBUCKET_REPO_SLUG=

# ── GitHub (when VCS_PROVIDER=github) ──
# Fine-grained personal-access token with scopes:
#   Contents: read+write, Pull requests: read+write, Actions: read+write
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# Workflow file that takes a `ref` input and deploys it (used by rollback_deploy).
GITHUB_DEPLOY_WORKFLOW=deploy.yml
# GitHub Enterprise base URL; leave default for github.com
GITHUB_API_BASE=https://api.github.com


# ===== Deploy tag conventions =====
# How your repo tags releases per environment.
# Format string: {env} is replaced with the env name; use leading/trailing parts as needed.
# Defaults below match: v0.0.1, v0.0.1-stag, v0.0.1-dev (prod tag has no env suffix).
DEPLOY_TAG_PROD_REGEX=^v\d+\.\d+\.\d+$
DEPLOY_TAG_NONPROD_SUFFIX_DEV=-dev
DEPLOY_TAG_NONPROD_SUFFIX_STAGING=-stag


# ===== Server runtime =====
MCP_HOST=127.0.0.1
MCP_PORT=8765

# Optional shared-secret token. If set, every MCP request must include
# `Authorization: Bearer <token>`. Leave blank for no auth (loopback only!).
MCP_BEARER_TOKEN=
