# ─────────────────────────────────────────────────────────────────────
# lgtm-oncall-mcp — configuration
# Copy this file to .env and fill in the values.
#
# Legend:
#   [REQUIRED]            — server fails to start without it
#   [REQUIRED for X]      — only required when the matching mode is selected
#   [OPTIONAL]            — has a sensible default, change only if needed
# ─────────────────────────────────────────────────────────────────────


# ════════════════════════════════════════════════════════════════════
# GRAFANA (always required — this is the LGTM stack entrypoint)
# ════════════════════════════════════════════════════════════════════

# [REQUIRED] Base URL of your Grafana instance.
GRAFANA_URL=https://grafana.example.com

# [REQUIRED] Grafana service-account token.
# Viewer scope is enough for every read tool. Editor only if you want to
# extend the server to mutate dashboards/alerts (no tool does that today).
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Mimir / Prometheus datasource UID in Grafana.
# Find it: Grafana → Connections → Data sources → click your Mimir source → UID.
MIMIR_DS_UID=

# [REQUIRED] Loki datasource UID (same path).
LOKI_DS_UID=

# [OPTIONAL] Pin the Grafana TLS cert to a file (recommended for self-signed
# Grafana). Leave empty to use the system trust store (works for public CAs).
# GRAFANA_CA_CERT_PATH=/etc/lgtm-oncall-mcp/grafana-ca.pem


# ════════════════════════════════════════════════════════════════════
# LABEL CONVENTIONS  (how YOUR services are labeled in Mimir/Loki)
# ════════════════════════════════════════════════════════════════════

# [OPTIONAL] Label key that identifies the environment. Default: env
ENV_LABEL_KEY=env

# [OPTIONAL] Label key that identifies your team. Default: team
TEAM_LABEL_KEY=team

# [OPTIONAL] Team label value. Leave empty to disable team filtering.
TEAM_LABEL_VALUE=


# ════════════════════════════════════════════════════════════════════
# VCS / DEPLOY BACKEND   — pick ONE: bitbucket OR github
# ════════════════════════════════════════════════════════════════════

# [REQUIRED] Which VCS to use. Options: bitbucket, github
VCS_PROVIDER=bitbucket


# ─────────────────────────────────────────────────────────────
# Option A — Bitbucket Cloud  (fill these if VCS_PROVIDER=bitbucket)
# Leave them blank if VCS_PROVIDER=github.
# ─────────────────────────────────────────────────────────────

# Atlassian API token + email (NOT username+password). Token scopes needed:
#   read:repository:bitbucket
#   read:pullrequest:bitbucket
#   write:repository:bitbucket    (only if you use propose_fix_pr)
#   write:pullrequest:bitbucket   (only if you use propose_fix_pr)
#   read:pipeline:bitbucket
#   write:pipeline:bitbucket      (only if you use rollback_deploy)

# [REQUIRED for bitbucket]
BITBUCKET_EMAIL=
# [REQUIRED for bitbucket]
BITBUCKET_API_TOKEN=
# [REQUIRED for bitbucket]  e.g. mycompany
BITBUCKET_WORKSPACE=
# [REQUIRED for bitbucket]  e.g. my-app
BITBUCKET_REPO_SLUG=


# ─────────────────────────────────────────────────────────────
# Option B — GitHub  (fill these if VCS_PROVIDER=github)
# Leave them blank if VCS_PROVIDER=bitbucket.
# ─────────────────────────────────────────────────────────────

# Fine-grained PAT scoped to ONE repo. Permissions needed:
#   Contents:      read (+ write only if you use propose_fix_pr)
#   Pull requests: read (+ write only if you use propose_fix_pr)
#   Actions:       read (+ write only if you use rollback_deploy)

# [REQUIRED for github]
GITHUB_TOKEN=
# [REQUIRED for github]  e.g. myorg or your-username
GITHUB_OWNER=
# [REQUIRED for github]  e.g. my-app
GITHUB_REPO=

# [REQUIRED for github] Workflow file that takes a `ref` input and deploys it.
# This is what rollback_deploy dispatches. Must exist at:
#   .github/workflows/<GITHUB_DEPLOY_WORKFLOW>
# in your repo, with `on: workflow_dispatch` configured.
GITHUB_DEPLOY_WORKFLOW=deploy.yml

# [OPTIONAL] GitHub Enterprise base URL. Default works for github.com.
GITHUB_API_BASE=https://api.github.com


# ════════════════════════════════════════════════════════════════════
# DEPLOY TAG CONVENTIONS  (how YOUR repo tags releases per env)
# ════════════════════════════════════════════════════════════════════
# Defaults match: v0.0.1 (prod), v0.0.1-stag (staging), v0.0.1-dev (dev)

# [OPTIONAL] Regex that matches PROD tags (env="prod").
DEPLOY_TAG_PROD_REGEX=^v\d+\.\d+\.\d+$

# [OPTIONAL] Suffix for DEV tags (env="dev").
DEPLOY_TAG_NONPROD_SUFFIX_DEV=-dev

# [OPTIONAL] Suffix for STAGING tags (env="staging").
DEPLOY_TAG_NONPROD_SUFFIX_STAGING=-stag


# ════════════════════════════════════════════════════════════════════
# SERVER RUNTIME
# ════════════════════════════════════════════════════════════════════

# [OPTIONAL] Bind address. Default 127.0.0.1 = loopback only.
# Set 0.0.0.0 only if you also set MCP_BEARER_TOKEN.
MCP_HOST=127.0.0.1

# [OPTIONAL] Port. Default 8765.
MCP_PORT=8765

# [OPTIONAL — but REQUIRED if you bind beyond loopback]
# Shared secret. If set, every request must include
#   Authorization: Bearer <this value>
# Generate one with:  openssl rand -hex 32
# Leave blank for loopback-only setups.
MCP_BEARER_TOKEN=


# ════════════════════════════════════════════════════════════════════
# GUARDRAILS  (server-side safety gates for destructive tools)
# ════════════════════════════════════════════════════════════════════
# Destructive tools (rollback_deploy, propose_fix_pr) are split into
#   propose_*  (no side effect, returns proposal_id)
#   confirm_*  (executes, requires proposal_id within TTL)
# This forces two deliberate tool calls.

# [OPTIONAL] How long a proposal_id stays valid before confirm_* must be
# called. Default 600s (10 min) — enough for a human to read the proposal
# in chat, think, and reply. Drop lower (e.g. 60s) only if your callers
# are autonomous agents with sub-second latency.
PROPOSAL_TTL_SECONDS=600

# [OPTIONAL] Append-only audit log file. If unset, events go to stderr only
# (still captured by systemd journal / container runtime).
# AUDIT_LOG_PATH=/var/log/lgtm-oncall-mcp/audit.jsonl
